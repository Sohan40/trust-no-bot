# OpenAI API key used by the AI provider.
# Do not commit a real key.
OPENAI_API_KEY=

# Optional server-only model override.
OPENAI_MODEL=gpt-4.1-mini

# App URL used for share links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project URL and publishable anon key.
# NEXT_PUBLIC_* variables can be exposed to the browser, but this MVP uses
# server-side repositories for hidden game state.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key used by lib/db repositories.
# Never expose this in client components or NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=

# Optional direct database URL for local Supabase CLI / migrations.
# DATABASE_URL=

# Optional analytics key later.
# NEXT_PUBLIC_ANALYTICS_KEY=
