# Server-only OpenAI configuration. OPENAI_API_KEY enables live dialogue;
# without it, the app intentionally falls back to deterministic mock dialogue.
# Never prefix either variable with NEXT_PUBLIC_ or commit a real key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional server-only public-test guardrails. Defaults are shown.
MAX_GAMES_PER_DAY=3
MAX_AI_ACTIONS_PER_DAY=30
MAX_QUESTIONS_PER_GAME=5

# Browser-visible app URL. Use the canonical production URL in Vercel Production
# and the relevant preview URL only when preview-specific links are needed.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Browser-visible Supabase project URL and publishable/anon key.
# These are identifiers, not privileged database credentials. The current MVP
# still routes hidden game-state access through server-side repositories.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key used by lib/db repositories. This bypasses RLS and
# must never be imported into client components or renamed with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Optional direct database URL for local Supabase CLI / migrations.
# DATABASE_URL=

# Optional analytics key later.
# NEXT_PUBLIC_ANALYTICS_KEY=
